# ── Docker Compose Environment ──────────────────────
# Copy this to .env and fill in values before running docker compose

# PostgreSQL
POSTGRES_USER=reimburse
POSTGRES_PASSWORD=change_me_to_a_strong_password
POSTGRES_DB=reimburse_db

# JWT — MUST change in production
JWT_SECRET_KEY=change_me_to_a_random_64_char_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# OCR (optional — leave empty to disable)
MINDEE_API_KEY=
OLLAMA_URL=http://host.docker.internal:11434
OCR_MODEL=glm-ocr:latest

# Frontend URL (used for CORS)
FRONTEND_URL=http://localhost

# SMTP (optional — leave empty to disable email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# Password reset
PASSWORD_RESET_EXPIRE_MINUTES=30
